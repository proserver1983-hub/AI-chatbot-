# ============================================================
# ChatFlow AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# -----------------------------------------------------------
# AI PROVIDER KEYS (at least one required for real AI responses)
# The system tries each provider in order; falls back to
# intelligent FAQ/business-info matching if none are set.
# -----------------------------------------------------------

# OpenAI (default: gpt-4o-mini)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (default: gemini-pro)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude (default: claude-3-haiku-20240307)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# SUPABASE (optional — app works with localStorage without these)
# Required for persistent cloud database, auth, and storage.
# -----------------------------------------------------------

# Server-side keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx

# Client-side keys (same URL/anon key, prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx
